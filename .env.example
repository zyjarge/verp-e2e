# =========================================
# Verp 端到端 UI 测试环境变量
# 复制为 .env 后填值；.env 不要提交到 git
# =========================================

# ---- 被测目标 ----
# 你的本机 / 公司测试环境（前端入口）
VERP_WEB_URL=https://verpapi.duodutech.com

# ---- 跑测试用账号（按 Verp README 默认 seed）----
# 商户管理员
VERP_E2E_USER=admin
VERP_E2E_PASSWORD=Admin@123
# 平台管理员（用于平台级菜单验证）
VERP_E2E_PLATFORM_USER=platform
VERP_E2E_PLATFORM_PASSWORD=Admin@123

# ---- 浏览器行为 ----
HEADLESS=true
CI=false